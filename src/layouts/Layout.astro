---
import '@fontsource/lora/400.css';
import '@fontsource/lora/500.css';
import '@fontsource/lora/600.css';
import '@fontsource/lora/700.css';
import '@fontsource/red-hat-mono/400.css';
import '@fontsource/red-hat-mono/500.css';
import '@fontsource/red-hat-mono/600.css';
import '@fontsource/red-hat-mono/700.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    
    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
  </head>
  <body>
    <!-- Persistent Offline Banner will be controlled dynamically on the client side -->
    <div id="offline-banner" class="offline-banner" style="display: none;">
      <div class="banner-content">
        <span class="banner-icon">🔌</span>
        <span class="banner-text">You are currently offline. Checking connection to the backend...</span>
      </div>
    </div>

    <header class="app-header">
      <div class="container d-flex justify-content-between align-items-center w-100">
        <a href="/" class="brand-logo">
          <div class="logo-box">ES</div>
          <span class="logo-text">es-timados</span>
        </a>
      </div>
    </header>

    <main style="padding: 2.5rem 0;">
      <div class="container">
        <slot />
      </div>
    </main>

    <style is:global>
      :root {
        --bg-dark-obsidian: #fef9ed;
        --bg-dark-charcoal: #ffffff;
        --bg-dark-panel: #f7ecd9;
        --border-color: rgba(93, 82, 75, 0.12);
        --text-white: #2e2621;
        --text-gray-light: #5d524b;
        --text-gray-muted: #8c7e75;
        --text-gray-dark: #b5a99f;
        --gradient-brand: linear-gradient(135deg, #f2a8a8 0%, #ecd074 50%, #86cdab 100%);
        --gradient-glow: 0 10px 30px rgba(93, 82, 75, 0.05);
        --font-sans: "Lora", Georgia, serif;
        --font-mono: "Red Hat Mono", "Courier New", monospace;
        --transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }

      html, body {
        background-color: var(--bg-dark-obsidian);
        color: var(--text-gray-light);
        font-family: var(--font-sans);
        margin: 0;
        padding: 0;
        min-height: 100vh;
      }

      body {
        background-image: 
          radial-gradient(circle at 10% 20%, rgba(242, 168, 168, 0.08) 0%, transparent 50%),
          radial-gradient(circle at 90% 15%, rgba(236, 208, 116, 0.08) 0%, transparent 40%),
          radial-gradient(circle at 50% 85%, rgba(134, 205, 171, 0.08) 0%, transparent 50%);
        background-attachment: fixed;
      }

      /* Offline Banner styles */
      .offline-banner {
        background: #ef6f6f;
        color: #ffffff;
        text-align: center;
        padding: 0.75rem 1rem;
        font-weight: 600;
        font-family: var(--font-mono);
        box-shadow: 0 4px 15px rgba(239, 111, 111, 0.2);
        position: sticky;
        top: 0;
        z-index: 10000;
        animation: slideDown 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
      }

      @keyframes slideDown {
        from { transform: translateY(-100%); }
        to { transform: translateY(0); }
      }

      .banner-content {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-size: 0.95rem;
      }

      /* Custom Scrollbars */
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }

      ::-webkit-scrollbar-track {
        background: var(--bg-dark-obsidian);
      }

      ::-webkit-scrollbar-thumb {
        background: var(--bg-dark-panel);
        border-radius: 4px;
      }

      ::-webkit-scrollbar-thumb:hover {
        background: var(--text-gray-muted);
      }

      a {
        color: #5d524b;
        text-decoration: none;
        font-weight: 500;
        transition: var(--transition-smooth);
      }

      a:hover {
        color: #2e2621;
        text-decoration: underline;
      }

      h1, h2, h3, h4, h5, h6 {
        color: var(--text-white);
        font-weight: 600;
        letter-spacing: -0.02em;
      }

      /* Glassmorphism Cards */
      .glow-card {
        background: var(--bg-dark-charcoal);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 2rem;
        position: relative;
        box-shadow: 0 8px 32px 0 rgba(93, 82, 75, 0.04);
        transition: var(--transition-smooth);
      }

      .glow-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 40px 0 rgba(93, 82, 75, 0.08);
        border-color: rgba(93, 82, 75, 0.2);
      }

      /* Interactive Estimation Cards */
      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        gap: 1.25rem;
        margin-top: 1.5rem;
      }

      .estimados-card {
        background: var(--bg-dark-charcoal);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        height: 140px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        font-family: var(--font-mono);
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--text-white);
        transition: var(--transition-smooth);
        user-select: none;
        box-shadow: 0 4px 12px rgba(93, 82, 75, 0.03);
      }

      .estimados-card:hover {
        transform: translateY(-4px);
        border-color: var(--text-white);
        box-shadow: 0 8px 20px rgba(93, 82, 75, 0.08);
      }

      .estimados-card.active-selected {
        background: var(--text-white);
        color: var(--bg-dark-obsidian);
        border-color: var(--text-white);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(46, 38, 33, 0.15);
      }

      .estimados-card.special-card {
        font-size: 1rem;
        text-align: center;
        padding: 0.5rem;
      }

      /* Inputs and Forms */
      .form-group {
        margin-bottom: 1.5rem;
      }

      .form-label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-gray-muted);
        margin-bottom: 0.5rem;
      }

      .form-control, .form-select {
        background-color: #ffffff;
        border: 1px solid var(--border-color);
        color: var(--text-white);
        border-radius: 30px;
        padding: 0.75rem 1.25rem;
        width: 100%;
        font-family: var(--font-mono);
        font-size: 0.9rem;
        transition: var(--transition-smooth);
      }

      .form-control:focus, .form-select:focus {
        background-color: #ffffff;
        color: var(--text-white);
        border-color: var(--text-white);
        outline: none;
        box-shadow: 0 0 0 3px rgba(46, 38, 33, 0.08);
      }

      /* Premium Buttons */
      .btn-premium {
        background: var(--text-white);
        color: var(--bg-dark-obsidian);
        font-family: var(--font-mono);
        font-weight: 600;
        border: 1px solid var(--text-white);
        padding: 0.75rem 1.8rem;
        border-radius: 30px;
        cursor: pointer;
        transition: var(--transition-smooth);
      }

      .btn-premium:hover {
        background: transparent;
        color: var(--text-white);
        transform: translateY(-2px);
      }

      .btn-outline-premium {
        background: transparent;
        border: 1px solid var(--text-white);
        color: var(--text-white);
        font-family: var(--font-mono);
        font-weight: 600;
        padding: 0.7rem 1.8rem;
        border-radius: 30px;
        cursor: pointer;
        transition: var(--transition-smooth);
      }

      .btn-outline-premium:hover {
        background: var(--text-white);
        color: var(--bg-dark-obsidian);
        transform: translateY(-2px);
      }

      /* Disabled state styling */
      button:disabled, button[disabled], button.disabled {
        cursor: not-allowed !important;
        transition: none !important;
      }

      .btn-premium:disabled, .btn-premium[disabled], .btn-premium.disabled {
        background: #dfd3be !important;
        color: var(--text-gray-dark) !important;
        border-color: #dfd3be !important;
        box-shadow: none !important;
        transform: none !important;
        transition: none !important;
      }

      .btn-premium:disabled:hover, .btn-premium[disabled]:hover, .btn-premium.disabled:hover {
        background: #dfd3be !important;
        transform: none !important;
        box-shadow: none !important;
        transition: none !important;
      }

      .btn-outline-premium:disabled, .btn-outline-premium[disabled], .btn-outline-premium.disabled {
        background: transparent !important;
        border: 1px solid #dfd3be !important;
        color: #dfd3be !important;
        transform: none !important;
        box-shadow: none !important;
        transition: none !important;
      }

      .btn-outline-premium:disabled:hover, .btn-outline-premium[disabled]:hover, .btn-outline-premium.disabled:hover {
        border-color: #dfd3be !important;
        color: #dfd3be !important;
        transform: none !important;
        transition: none !important;
      }

      /* Header branding */
      .app-header {
        height: 70px;
        border-bottom: 1px solid var(--border-color);
        background: rgba(254, 249, 237, 0.8);
        backdrop-filter: blur(16px);
        display: flex;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .brand-logo {
        display: flex;
        align-items: center;
        gap: 12px;
        font-family: var(--font-mono);
        font-weight: 700;
        font-size: 1.15rem;
      }

      .logo-box {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: var(--text-white);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--bg-dark-obsidian);
        font-family: var(--font-mono);
        font-weight: 800;
        font-size: 0.95rem;
      }

      .logo-text {
        background: linear-gradient(135deg, #e38d8d 0%, #d5ba58 50%, #6ab28f 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 800;
      }

      /* Waiting list */
      .waiting-participant {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1.25rem;
        background: var(--bg-dark-charcoal);
        border: 1px solid var(--border-color);
        border-radius: 30px;
        margin-bottom: 0.75rem;
        font-family: var(--font-mono);
        font-size: 0.9rem;
        transition: var(--transition-smooth);
      }

      .participant-name-text {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 160px;
        display: inline-block;
        vertical-align: middle;
      }

      .participant-observer-text .obs-short {
        display: none;
      }
      .participant-observer-text .obs-full {
        display: inline;
      }

      .pending-request-actions {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .pending-request-actions button {
        flex: 1 1 auto;
        min-width: 80px;
        text-align: center;
      }

      @media (max-width: 1200px) {
        .participant-name-text {
          max-width: 100px;
        }
      }

      @media (max-width: 991px) {
        .waiting-participant {
          flex-wrap: wrap;
          border-radius: 16px;
          padding: 0.75rem 1rem;
        }
        .waiting-participant > :first-child {
          flex: 1 1 50%;
          min-width: 140px;
        }
        .waiting-participant > :last-child {
          flex: 0 0 auto;
          text-align: right;
        }
        .waiting-participant > .pending-request-actions {
          flex: 1 1 100%;
          margin-top: 0.5rem;
          justify-content: stretch;
        }
        .participant-observer-text .obs-full {
          display: none;
        }
        .participant-observer-text .obs-short {
          display: inline;
        }
      }

      /* State & Step Indicators */
      .step-badge {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        padding: 6px 14px;
        border-radius: 20px;
        background: rgba(93, 82, 75, 0.05);
        color: var(--text-white);
        border: 1px solid var(--border-color);
      }

      .step-badge.inactive {
        background: transparent;
        color: var(--text-gray-dark);
        border-color: var(--border-color);
      }
    </style>
  </body>
</html>
